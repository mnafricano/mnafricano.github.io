{
  "name": "@mnafricano/revenue-auditor",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,html,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,html,css,md}\"",
    "lint": "eslint src e2e vite.config.ts playwright.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm format:check && pnpm lint && tsc -b --pretty false && vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.52.0",
    "pdfjs-dist": "^5.3.31",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
